# Sao chép thành `.env.local`. Cùng Supabase project với app user — chỉ publishable trong browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# Public URL của **ứng dụng admin** (khác app user).
# Dev: có thể bỏ trống → dùng window.location.origin.
# Production (Vercel / hosting admin): bắt buộc đúng subdomain admin.
VITE_APP_URL=https://admin.ngaylanhthangtot.vn

# ── Supabase Dashboard → Authentication → URL Configuration ───────────────
# Site URL có thể vẫn là app user: https://ngaylanhthangtot.vn
#
# Redirect URLs (Additional): **thêm** callback của admin, ví dụ:
#   https://admin.ngaylanhthangtot.vn/auth/callback
#   http://localhost:5173/auth/callback   (port dev admin nếu khác thì sửa)
#
# Không thay Site URL bằng admin trừ khi bạn chủ đích — chỉ cần whitelist redirect admin.
#
# Edge Function admin-dashboard-stats (trong repo này: supabase/functions/):
#   cd repo admin → supabase link --project-ref <ref> (cùng project app user)
#   supabase secrets set ADMIN_EMAILS=you@corp.com,other@corp.com
#   supabase functions deploy admin-dashboard-stats
